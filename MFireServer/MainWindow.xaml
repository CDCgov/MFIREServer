<Window x:Class="MFireServer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:local="clr-namespace:MFireServer"
        mc:Ignorable="d"
		ShowActivated="False"
        WindowState="Minimized"
		Closing="OnClosing"
        ShowInTaskbar="True"
        Title="MFireServer" Height="750" Width="900">
	<!--Visibility="Hidden"-->

    <Window.Resources>
        <BitmapImage UriSource="/nearby_error_red.png" x:Key="ErrorImage"/>
    </Window.Resources>
    
    <Window.TaskbarItemInfo>
        <TaskbarItemInfo x:Name="taskBarItemInfo" Description="MFIRE Server" />
        <!--" Overlay="{StaticResource ResourceKey=ErrorImage}"-->
        
    </Window.TaskbarItemInfo>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="220" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="150" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>
        
        
        <GroupBox DockPanel.Dock="Top" Grid.ColumnSpan="2" Header="Status" Margin="3">
            <ListView Margin="6" x:Name="lstStatusItems">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding StatusText}" />
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.Items>
                    <local:MFIREStatusItem x:Name="statusElapsed" StatusText="Elapsed Time: 00:00:00" />
                    <local:MFIREStatusItem StatusText="Elapsed Time: 00:00:00" />
                </ListView.Items>
            </ListView>

        </GroupBox>

        <Grid  Margin="3" Grid.Column="1" Grid.Row="1">
            <DockPanel >
                <TextBlock Text="Clients" Height="23" DockPanel.Dock="Top"/>
                <ListView x:Name="lstConnectedClients" ItemsSource="{Binding}">
                
                </ListView>
            </DockPanel>
        </Grid>

        <TabControl Grid.Row="1" Margin="3">
            <TabItem Header="Log">
                <ScrollViewer>
                    <TextBlock x:Name="txtLog" FontFamily="Courier New" />
                </ScrollViewer>
            </TabItem>

            <TabItem Header="MFire Output">

                <ScrollViewer>
                    <TextBlock x:Name="txtOutput" FontFamily="Courier New" />
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Sim Status">

                <ScrollViewer>
                    <TextBlock x:Name="txtSimStatus" FontFamily="Courier New" />
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Debug">

                <ScrollViewer>
                    <TextBlock x:Name="txtDebugLog" FontFamily="Courier New" />
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <GroupBox Header="Errors" Grid.Row="2" Grid.ColumnSpan="2" Margin="3">
            <TextBlock x:Name="txtErrors"></TextBlock>
        </GroupBox>

        <StackPanel Orientation="Horizontal" DockPanel.Dock="Bottom" Grid.Row="3" Grid.ColumnSpan="2" HorizontalAlignment="Right">
			<Button Click="OnClickedExit" Content="Exit" Margin="3" Padding="3" Width="70" />
		</StackPanel>

		
        <tb:TaskbarIcon x:Name="myNotifyIcon"
                    Visibility="Visible"
                    ToolTipText="MFire Server"
                    MenuActivation="LeftOrRightClick"
                    PopupActivation="DoubleClick"
                    TrayMouseDoubleClick="OnTrayDoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Show window" Click="OnMenuShowWindow" />
                    <MenuItem Header="Exit" Click="OnMenuExit" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Grid>
</Window>
