<Window x:Class="MFireServer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:local="clr-namespace:MFireServer"
        mc:Ignorable="d"
		ShowActivated="False"
        WindowState="Minimized"
		Closing="OnClosing"
        ShowInTaskbar="True"
        Title="MFIRE Server" Height="750" Width="900">
	<!--Visibility="Hidden"-->

    <Window.Resources>
        <BitmapImage x:Key="ErrorImage" UriSource="/GoogleMaterialDesignIcons/nearby_error_red.png" />
        <BitmapImage x:Key="FireDeptImage" UriSource="/GoogleMaterialDesignIcons/local_fire_department_24dp_000000.png" />
        <BitmapImage x:Key="NumberImage" UriSource="/GoogleMaterialDesignIcons/numbers_24dp_000000.png" />
        <BitmapImage x:Key="FanImage" UriSource="/GoogleMaterialDesignIcons/mode_fan_24dp_000000.png" />
        <BitmapImage x:Key="TimeImage" UriSource="/GoogleMaterialDesignIcons/timer_24dp_000000.png" />
        <BitmapImage x:Key="SpeedImage" UriSource="/GoogleMaterialDesignIcons/speed_24dp_000000.png" />
    </Window.Resources>
    
    <Window.TaskbarItemInfo>
        <TaskbarItemInfo x:Name="taskBarItemInfo" Description="MFIRE Server" />
        <!--" Overlay="{StaticResource ResourceKey=ErrorImage}"-->
        
    </Window.TaskbarItemInfo>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="220" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="150" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>
        
        
        <GroupBox DockPanel.Dock="Top" Grid.ColumnSpan="2" Header="Status" Margin="3">
            <ListView Margin="3" x:Name="lstStatusItems" BorderThickness="0" BorderBrush="Transparent">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <BulletDecorator>
                            <BulletDecorator.Bullet>
                                <Image Source="{Binding Image}" Width="16"/>
                            </BulletDecorator.Bullet>
                            <TextBlock Padding="6 0 0 0" Text="{Binding StatusText}" />
                        </BulletDecorator>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2" ></UniformGrid>
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <ListView.Items>
                    <local:MFIREStatusItem x:Name="statusSimTime" StatusText="Sim Time:" Image="{StaticResource TimeImage}" />
                    <local:MFIREStatusItem x:Name="statusComputeTime" StatusText="Compute Time (ms):" Image="{StaticResource SpeedImage}" />
                    <local:MFIREStatusItem x:Name="statusNumJunctions" StatusText="Num Junctions:" Image="{StaticResource NumberImage}"/>
                    <local:MFIREStatusItem x:Name="statusNumAirways" StatusText="Num Airways:" Image="{StaticResource NumberImage}"/>
                    <local:MFIREStatusItem x:Name="statusNumFires" StatusText="Num Fires:" Image="{StaticResource FireDeptImage}" />
                    <local:MFIREStatusItem x:Name="statusNumFans" StatusText="Num Fans:" Image="{StaticResource FanImage}"/>
                    
                </ListView.Items>
            </ListView>

        </GroupBox>

        <Grid  Margin="3" Grid.Column="1" Grid.Row="1">
            <DockPanel >
                <TextBlock Text="Clients" Height="23" DockPanel.Dock="Top"/>
                <ListView x:Name="lstConnectedClients" ItemsSource="{Binding}">
                
                </ListView>
            </DockPanel>
        </Grid>

        <TabControl Grid.Row="1" Margin="3">
            <TabItem Header="Log">
                <ScrollViewer>
                    <TextBlock x:Name="txtLog" FontFamily="Courier New" />
                </ScrollViewer>
            </TabItem>

            <TabItem Header="MFire Output">

                <ScrollViewer>
                    <TextBlock x:Name="txtOutput" FontFamily="Courier New" />
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Sim Status">

                <ScrollViewer>
                    <TextBlock x:Name="txtSimStatus" FontFamily="Courier New" />
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Debug">

                <ScrollViewer>
                    <TextBlock x:Name="txtDebugLog" FontFamily="Courier New" />
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <GroupBox Header="Errors" Grid.Row="2" Grid.ColumnSpan="2" Margin="3">
            <TextBlock x:Name="txtErrors"></TextBlock>
        </GroupBox>

        <StackPanel Orientation="Horizontal" DockPanel.Dock="Bottom" Grid.Row="3" Grid.ColumnSpan="2" HorizontalAlignment="Right">
			<Button Click="OnClickedExit" Content="Exit" Margin="3" Padding="3" Width="70" />
		</StackPanel>

		
        <tb:TaskbarIcon x:Name="myNotifyIcon"
                    Visibility="Visible"
                    ToolTipText="MFire Server"
                    MenuActivation="LeftOrRightClick"
                    PopupActivation="DoubleClick"
                    TrayMouseDoubleClick="OnTrayDoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Show window" Click="OnMenuShowWindow" />
                    <MenuItem Header="Exit" Click="OnMenuExit" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Grid>
</Window>
